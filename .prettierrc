{
  "overrides": [
    {
      "files": ["*.json", "**/*.json"],
      "options": {
        "tabWidth": 4,
        "plugins": ["prettier-plugin-multiline-arrays"],
        "multilineArraysWrapThreshold": 1
      }
    },
    {
      "files": ["*.md", "**/*.md"],
      "options": {
        "printWidth": 80,
        "proseWrap": "always"
      }
    }
  ]
}
