{
    "name": "Personal",
    "id": "personal",
    "version": "1.0.1",
    "description": "Install personal tools for devcontainers.",
    "options": {
        "nvim_version": {
            "type": "string",
            "default": "stable",
            "description": "Neovim version passed to the neovim-prebuilt feature."
        }
    },
    "dependsOn": {
        "ghcr.io/devcontainers-extra/features/age:1": {},
        "ghcr.io/devcontainers/features/git": {},
        "ghcr.io/devcontainers-extra/features/curl-apt-get:1": {},
        "ghcr.io/devcontainers-extra/features/tmux-apt-get:1": {},
        "ghcr.io/devcontainers-extra/features/gitmux:1": {},
        "ghcr.io/engma324/devcontainer-features/persistent-home:1": {},
        "ghcr.io/engma324/devcontainer-features/opencode:1": {},
        "ghcr.io/LCerebo/devcontainer-features/lazyvim:1": {
            "version": "${nvim_version}"
        }
    }
}
